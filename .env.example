# XPALLA configuration — copy this file to ".env" and fill in your values.
# The .env file is read automatically by server.js on startup.

# --- Supabase (database) ---
# Supabase dashboard → Project Settings → Data API / API.
#  • SUPABASE_URL          = your Project URL (https://xxxx.supabase.co)
#  • SUPABASE_SERVICE_KEY  = the "service_role" secret key (NOT the anon key).
# IMPORTANT: the service_role key has full database access. It lives ONLY here,
# server-side. Never put it in the browser/frontend or commit it to git.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Optional: real Claude generation (otherwise the app uses demo mode) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-sonnet-latest
